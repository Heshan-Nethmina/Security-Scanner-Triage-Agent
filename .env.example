# Copy this file to ".env" and fill in real values:  cp .env.example .env
# ".env" is gitignored, so your real secrets are never committed.
#
# Nothing here is used until Phase 3 (the LLM client). It lives here now so the
# "secrets and config come from the environment, never hardcoded" habit is in
# place from the very start.

# --- LLM provider selection (provider-agnostic by design) ---
# We default to Anthropic Claude, but keep the provider + model in config so an
# open model can be swapped in by changing one value. The exact model is chosen
# in Phase 3 -- these are just illustrative.
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6

# --- API keys ---
# ANTHROPIC_API_KEY=sk-ant-...
