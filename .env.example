# Copy this file to ".env" and fill in your real key:  cp .env.example .env
# ".env" is gitignored, so your real secrets are never committed.

# --- LLM provider + model (provider-agnostic by design) ---
# The app reads these into LLMConfig; swapping providers is a one-value change.
# If unset, the defaults are: provider=groq, model=llama-3.3-70b-versatile.
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
# Other Groq options: openai/gpt-oss-120b (reasoning), llama-3.1-8b-instant (cheapest)

# --- API key (only the one for your chosen provider is needed) ---
GROQ_API_KEY=your-groq-key-here

# To use Anthropic instead, set:
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-opus-4-8
#   ANTHROPIC_API_KEY=sk-ant-...
